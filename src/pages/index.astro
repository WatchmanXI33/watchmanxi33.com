---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import Card from '../components/Card.astro';
import FeaturedPost from '../components/FeaturedPost.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import TagsCloud from '../components/TagsCloud.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getDraftModeProps } from '../sanity/lib/draft-mode';
import { loadQuery } from '../sanity/lib/load-query';
import { POSTS_QUERY } from '../utils/sanity';
import type { CollectionEntry } from 'astro:content';
import type { SanityPostListItem } from '../types/sanity';

const { data: sanityPosts } = await loadQuery<SanityPostListItem[]>({
	query: POSTS_QUERY,
	...getDraftModeProps(Astro.cookies),
}).catch(() => ({ data: null }));
const localPosts = (await getCollection('blog'))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const usingSanity = !!sanityPosts;
const allPosts = (sanityPosts ?? localPosts).filter(Boolean);

const recentPosts = allPosts.slice(0, 6);
const featured = usingSanity
	? (recentPosts as SanityPostListItem[]).find((p) => p.featured)
	: (recentPosts as CollectionEntry<'blog'>[]).find((p) => p.data.featured);
const displayed = sanityPosts
	? recentPosts.filter((p: SanityPostListItem) => !p.featured || p.slug !== (featured as SanityPostListItem)?.slug)
	: recentPosts.filter((p: CollectionEntry<'blog'>) => !p.data.featured || p.id !== (featured as CollectionEntry<'blog'>)?.id);

let featuredCardPost: { id: string; data: Record<string, any> } | undefined;
if (featured) {
	featuredCardPost = sanityPosts
		? {
				id: featured.slug,
				data: {
					title: featured.title,
					description: featured.description ?? '',
					pubDate: featured.publishedAt ? new Date(featured.publishedAt) : new Date(0),
					updatedDate: featured.updatedAt ? new Date(featured.updatedAt) : undefined,
					heroImage: featured.mainImage?.asset ? { src: featured.mainImage.asset.url } : undefined,
					categories: featured.categories ?? [],
					tags: featured.tags ?? [],
					author: featured.author,
					featured: featured.featured,
				},
			}
		: (featured as CollectionEntry<'blog'>);
}
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
		<main class="max-w-6xl mx-auto px-4 py-12">
			<section class="mb-16 text-center">
				<h1 class="text-4xl md:text-5xl font-bold text-gray-900 dark:text-white mb-4">
					{SITE_TITLE}
				</h1>
				<p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
					{SITE_DESCRIPTION}
				</p>
			</section>

			<FeaturedPost post={featuredCardPost} />

			<section class="mb-16">
				<h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-8">Recent Posts</h2>
				<div class="grid gap-8 md:grid-cols-2 lg:grid-cols-3">
					{displayed.map((post) => {
						const cardPost = sanityPosts
							? {
									id: post.slug,
									data: {
										title: post.title,
										description: post.description ?? '',
										pubDate: post.publishedAt ? new Date(post.publishedAt) : new Date(0),
										updatedDate: post.updatedAt ? new Date(post.updatedAt) : undefined,
										heroImage: post.mainImage?.asset ? { src: post.mainImage.asset.url } : undefined,
										categories: post.categories ?? [],
										tags: post.tags ?? [],
										author: post.author,
										featured: post.featured,
									},
								}
							: post;
						return <Card post={cardPost} />;
					})}
				</div>
				<div class="text-center mt-10">
					<a
						href="/blog"
						class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-medium text-sm transition-colors no-underline"
					>
						View all posts
						<svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
							<path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" />
						</svg>
					</a>
				</div>
			</section>

			<div class="mb-16">
				<TagsCloud posts={allPosts} />
			</div>

			<NewsletterSignup />
		</main>
	</Layout>