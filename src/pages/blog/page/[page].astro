---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import Card from '../../../components/Card.astro';
import NewsletterSignup from '../../../components/NewsletterSignup.astro';
import Pagination from '../../../components/Pagination.astro';
import TagsCloud from '../../../components/TagsCloud.astro';
import { BLOG, SITE_DESCRIPTION } from '../../../consts';
import { getDraftModeProps } from '../../../sanity/lib/draft-mode';
import { loadQuery } from '../../../sanity/lib/load-query';
import { POSTS_QUERY } from '../../../utils/sanity';
import type { SanityPostListItem } from '../../../types/sanity';

const currentPage = parseInt(Astro.params.page || '1', 10);

const { data: sanityPosts } = await loadQuery<SanityPostListItem[]>({
	query: POSTS_QUERY,
	...getDraftModeProps(Astro.cookies),
}).catch(() => ({ data: null }));

const localPosts = (await getCollection('blog'))
	.filter((p) => !p.data.draft)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const allPosts = (sanityPosts ?? localPosts).filter(Boolean);
const totalPages = Math.ceil(allPosts.length / BLOG.postsPerPage);
const pagePosts = allPosts.slice(
	(currentPage - 1) * BLOG.postsPerPage,
	(currentPage * BLOG.postsPerPage),
);
---

<Layout title={`Blog — Page ${currentPage}`} description={SITE_DESCRIPTION}>
		<main class="max-w-6xl mx-auto px-4 py-12">
			<section class="mb-12">
				<h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-2">Blog</h1>
				<p class="text-gray-600 dark:text-gray-400">Explore all articles, tutorials, and insights.</p>
			</section>

			<div class="lg:grid lg:grid-cols-[1fr_280px] lg:gap-10">
				<div>
					<form class="mb-8" role="search" onsubmit="return false;">
						<div class="relative">
							<svg class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
								<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
							</svg>
							<input
								id="search-input"
								type="search"
								placeholder="Search posts..."
								class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 text-sm"
							/>
						</div>
					</form>

					<div id="posts-grid" class="grid gap-8 md:grid-cols-2">
						{pagePosts.map((post) => {
							const cardPost = sanityPosts
								? {
										id: post.slug,
										data: {
											title: post.title,
											description: post.description ?? '',
											pubDate: post.publishedAt ? new Date(post.publishedAt) : new Date(0),
											updatedDate: post.updatedAt ? new Date(post.updatedAt) : undefined,
											heroImage: post.mainImage?.asset ? { src: post.mainImage.asset.url } : undefined,
											categories: post.categories ?? [],
											tags: post.tags ?? [],
											author: post.author,
											featured: post.featured,
										},
									}
								: post;
							return <Card post={cardPost} />;
						})}
					</div>

					<div id="no-results" class="hidden text-center py-16">
						<svg class="w-16 h-16 mx-auto text-gray-300 dark:text-gray-600 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
							<path stroke-linecap="round" stroke-linejoin="round" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 8 0 11-18 0 9 8 0 0118 0z" />
						</svg>
						<p class="text-gray-500 dark:text-gray-400">No posts found matching your criteria.</p>
					</div>

					<div id="pagination">
						<Pagination currentPage={currentPage} totalPages={totalPages} base="/blog/" />
					</div>
				</div>

				<aside class="hidden lg:block space-y-8">
					<div class="sticky top-24 space-y-8">
						<TagsCloud posts={allPosts} />
					</div>
				</aside>
			</div>

			<div class="mt-16">
				<NewsletterSignup />
			</div>
		</main>
	</Layout>

<script>
	const searchInput = document.getElementById('search-input');
	const postsGrid = document.getElementById('posts-grid');
	const noResults = document.getElementById('no-results');
	const pagination = document.getElementById('pagination');

	let timeout;

	searchInput?.addEventListener('input', () => {
		clearTimeout(timeout);
		timeout = setTimeout(() => {
			const query = searchInput.value.toLowerCase().trim();
			const items = postsGrid?.querySelectorAll('article');
			let visible = 0;

			items?.forEach((item) => {
				const card = item.closest('.md\\:grid-cols-2 > *') || item;
				const title = item.querySelector('h3')?.textContent?.toLowerCase() || '';
				const desc = item.querySelector('p')?.textContent?.toLowerCase() || '';
				const matches = !query || title.includes(query) || desc.includes(query);
				card.classList.toggle('hidden', !matches);
				if (matches) visible++;
			});

			if (noResults) noResults.classList.toggle('hidden', visible > 0);
			if (pagination) pagination.classList.toggle('hidden', visible === 0);
		}, 200);
	});
</script>