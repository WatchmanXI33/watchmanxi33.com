---
import CodeBlock from '../../components/CodeBlock.astro';
import GiscusComments from '../../components/GiscusComments.astro';
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { PortableText } from 'astro-portabletext';
import { POST_QUERY } from '../../utils/sanity';
import AuthorBio from '../../components/AuthorBio.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import NewsletterSignup from '../../components/NewsletterSignup.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import TOC from '../../components/TOC.astro';
import { getDraftModeProps } from '../../sanity/lib/draft-mode';
import { loadQuery } from '../../sanity/lib/load-query';
import type { SanityBlock, SanityPostDetail } from '../../types/sanity';

const { slug } = Astro.params;

const { data: sanityPost } = await loadQuery<SanityPostDetail>({
	query: POST_QUERY,
	params: { slug },
	...getDraftModeProps(Astro.cookies),
}).catch(() => ({ data: null }));

let title: string;
let description: string;
let publishedAt: Date;
let updatedAt: Date | undefined;
let heroImage: any;
let categories: string[] = [];
let tags: string[] = [];
let author: string;
let body: any;
let postUrl: URL;
let readingTime: number;
let headings: { depth: number; slug: string; text: string }[] = [];
let localPost: any;

const ptComponents = {
	type: {
		code: CodeBlock,
	},
};

if (sanityPost) {
	title = sanityPost.title;
	description = sanityPost.description ?? '';
	publishedAt = sanityPost.publishedAt ? new Date(sanityPost.publishedAt) : new Date(0);
	updatedAt = sanityPost.updatedAt ? new Date(sanityPost.updatedAt) : undefined;
	heroImage = sanityPost.mainImage?.asset?.url ? { src: sanityPost.mainImage.asset.url } : undefined;
	categories = sanityPost.categories ?? [];
	tags = sanityPost.tags ?? [];
	author = sanityPost.author ?? 'Phil';
	body = sanityPost.body;
	postUrl = new URL(`/blog/${slug}/`, Astro.site);
	const blocks = sanityPost.body as SanityBlock[];
	readingTime = Math.ceil(
		((blocks || [])
			.filter((b) => b._type === 'block')
			.flatMap((b) => (b.children || []).filter((c) => c._type === 'span').map((c) => c.text))
			.join(' ')
			.match(/\S+/g) || []).length / 200,
	) || 1;
	headings = (blocks || [])
		.filter((b) => b._type === 'block' && /^h[2-3]$/.test(b.style))
		.map((b) => {
			const text = (b.children || [])
				.filter((c) => c._type === 'span')
				.map((c) => c.text)
				.join('');
			const slug = text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
			return { depth: parseInt(b.style[1]), slug, text };
		});
} else {
	const allPosts = await getCollection('blog');
	localPost = allPosts.find((p) => p.id === slug);
	if (!localPost) {
		return Astro.redirect('/404');
	}
	const { data } = localPost;
	const { Content, headings: h } = await render(localPost);
	headings = h;
	title = data.title;
	description = data.description;
	publishedAt = data.pubDate;
	updatedAt = data.updatedDate;
	heroImage = data.heroImage;
	categories = data.categories ?? [];
	tags = data.tags ?? [];
	author = data.author;
	body = Content;
	postUrl = new URL(`/blog/${slug}/`, Astro.site);
	readingTime = Math.ceil(
		localPost.body ? localPost.body.split(/\s+/).length / 200 : 1,
	);
}
---

<Layout title={title} description={description} image={heroImage} type="article">
	<Fragment slot="head">
		<meta property="article:published_time" content={publishedAt.toISOString()} />
		{updatedAt && <meta property="article:modified_time" content={updatedAt.toISOString()} />}
		{tags.map((tag) => <meta property="article:tag" content={tag} />)}
		<meta name="twitter:label1" value="Reading time" />
		<meta name="twitter:data1" value={`${readingTime} min read`} />
	</Fragment>
	<main class="max-w-6xl mx-auto px-4 py-8">
			<article>
				<header class="mb-8 text-center max-w-3xl mx-auto">
					<div class="flex items-center justify-center gap-2 mb-4">
						{categories.map((cat) => (
							<span class="text-xs font-medium px-2.5 py-0.5 rounded-full bg-blue-100 dark:bg-blue-900/50 text-blue-700 dark:text-blue-300">
								{cat}
							</span>
						))}
					</div>
					<h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-gray-900 dark:text-white leading-tight mb-4">
						{title}
					</h1>
					<p class="text-lg text-gray-600 dark:text-gray-400 mb-4">{description}</p>
					<div class="flex items-center justify-center gap-3 text-sm">
						<FormattedDate date={publishedAt} />
						<span class="text-gray-300 dark:text-gray-600">·</span>
						<span class="text-gray-500 dark:text-gray-400">{readingTime} min read</span>
					</div>
					{tags.length > 0 && (
						<div class="flex items-center justify-center gap-2 mt-4">
							{tags.map((tag) => (
								<a href={`/blog?tag=${encodeURIComponent(tag)}`} class="text-xs px-2.5 py-1 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400 no-underline hover:bg-gray-200 dark:hover:bg-gray-700 transition-colors">
									#{tag}
								</a>
							))}
						</div>
					)}
				</header>

				{heroImage?.src && (
					<div class="mb-10 -mx-4 md:mx-0">
						<img src={heroImage.src} alt="" class="w-full h-64 md:h-96 object-cover rounded-2xl" />
					</div>
				)}

				<div class="lg:grid lg:grid-cols-[1fr_220px] lg:gap-10 relative">
					<div class="prose prose-lg dark:prose-invert max-w-none prose-headings:font-bold prose-a:text-blue-600 dark:prose-a:text-blue-400 prose-pre:bg-gray-900 prose-pre:dark:bg-gray-800 prose-code:text-sm prose-code:bg-gray-100 dark:prose-code:bg-gray-800 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:before:content-none prose-code:after:content-none">
						{
							typeof body === 'object' && body?.length
								? <PortableText value={body} components={ptComponents} />
								: body
						}
					</div>
					<aside class="hidden lg:block">
						<div class="sticky top-24">
							<TOC headings={headings} />
						</div>
					</aside>
				</div>

				<div class="mt-8 max-w-3xl mx-auto">
					<ShareButtons title={title} url={postUrl.href} />
				</div>

				<div class="mt-8 max-w-3xl mx-auto">
					<AuthorBio />
				</div>

				<GiscusComments />

				<div class="mt-8 max-w-3xl mx-auto">
					<NewsletterSignup />
				</div>

				{localPost && (
					<div class="mt-8 max-w-3xl mx-auto">
						<RelatedPosts current={localPost} />
					</div>
				)}
			</article>
		</main>
	</Layout>
