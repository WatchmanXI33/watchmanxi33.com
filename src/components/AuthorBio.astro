---
import { AUTHOR } from '../consts';
---

<div class="flex items-start gap-4 p-6 rounded-2xl bg-gray-50 dark:bg-gray-900">
	<img src={AUTHOR.avatar} alt={AUTHOR.name} class="w-14 h-14 rounded-full bg-gray-200 dark:bg-gray-700 flex-shrink-0" />
	<div>
		<p class="font-semibold text-gray-900 dark:text-white">{AUTHOR.name}</p>
		<p class="text-sm text-gray-600 dark:text-gray-400 mt-1">{AUTHOR.bio}</p>
	</div>
</div>
