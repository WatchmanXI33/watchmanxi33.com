---
interface Heading {
	depth: number;
	slug: string;
	text: string;
}

interface Props {
	headings: Heading[];
}

const { headings } = Astro.props;
---

{
	headings.length > 0 && (
		<nav class="toc" aria-label="Table of contents">
			<h2 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3">On this page</h2>
			<ul class="space-y-2">
				{headings
					.filter((h) => h.depth <= 3)
					.map((h) => (
						<li>
							<a
								href={`#${h.slug}`}
								class="block text-sm no-underline transition-colors hover:text-blue-600 dark:hover:text-blue-400"
								style={{
									paddingLeft: `${(h.depth - 2) * 0.75}rem`,
									color: h.depth === 2 ? 'rgb(55, 65, 81)' : 'rgb(107, 114, 128)',
								}}
							>
								{h.text}
							</a>
						</li>
					))}
			</ul>
		</nav>
	)
}
