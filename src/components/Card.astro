---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';

interface Props {
	post: CollectionEntry<'blog'> | { id: string; data: Record<string, any> };
	featured?: boolean;
}

const { post, featured = false } = Astro.props;
const { data } = post;

function isAstroImage(img: any): boolean {
	return img && typeof img === 'object' && img.src && !img.src?.startsWith?.('http');
}
---

<article class:list={[
	'group',
	featured
		? 'col-span-full grid md:grid-cols-2 gap-6 md:gap-8 items-center'
		: 'flex flex-col',
]}>
	<a href={`/blog/${post.id}/`} class="block overflow-hidden rounded-xl no-underline">
		{data.heroImage ? (
			<>
				{isAstroImage(data.heroImage) ? (
					<img
						src={data.heroImage.src}
						alt=""
						class:list={[
							'object-cover w-full transition-transform duration-500 group-hover:scale-105',
							featured ? 'h-64 md:h-96' : 'h-48',
						]}
					/>
				) : (
					<img
						src={data.heroImage.src}
						alt=""
						class:list={[
							'object-cover w-full transition-transform duration-500 group-hover:scale-105 rounded-xl',
							featured ? 'h-64 md:h-96' : 'h-48',
						]}
					/>
				)}
			</>
		) : (
			<div class:list={[
				'bg-gradient-to-br from-blue-100 to-blue-200 dark:from-blue-900/30 dark:to-blue-800/30 flex items-center justify-center rounded-xl',
				featured ? 'h-64 md:h-96' : 'h-48',
			]}>
				<svg class="w-12 h-12 text-blue-400 dark:text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
					<path stroke-linecap="round" stroke-linejoin="round" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
				</svg>
			</div>
		)}
	</a>
	<div class="flex flex-col gap-2">
		<div class="flex items-center gap-2 flex-wrap">
			{data.categories?.slice(0, 2).map((cat: string) => (
				<a
					href={`/blog?category=${encodeURIComponent(cat)}`}
					class="text-xs font-medium px-2.5 py-0.5 rounded-full bg-blue-100 dark:bg-blue-900/50 text-blue-700 dark:text-blue-300 no-underline hover:bg-blue-200 dark:hover:bg-blue-900 transition-colors"
				>
					{cat}
				</a>
			))}
		</div>
		<a href={`/blog/${post.id}/`} class="no-underline group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
			<h3 class:list={[
				'font-bold text-gray-900 dark:text-white leading-tight',
				featured ? 'text-2xl md:text-3xl' : 'text-lg',
			]}>
				{data.title}
			</h3>
		</a>
		<p class="text-sm text-gray-600 dark:text-gray-400 line-clamp-2">
			{data.description}
		</p>
		<div class="flex items-center gap-2 text-sm">
			<FormattedDate date={data.pubDate} />
			{data.tags?.length > 0 && (
				<>
					<span class="text-gray-300 dark:text-gray-600">·</span>
					{data.tags.slice(0, 3).map((tag: string) => (
						<span class="text-gray-500 dark:text-gray-500">#{tag}</span>
					))}
				</>
			)}
		</div>
	</div>
</article>
