---
import { getCollection } from 'astro:content';

interface Props {
	posts?: Array<{ tags?: string[]; categories?: string[] }>;
}

const { posts: propPosts } = Astro.props;

const source = propPosts ?? (await getCollection('blog')).filter((p) => !p.data.draft);
const tags = new Map<string, number>();
const categories = new Map<string, number>();

for (const post of source) {
	const postTags = 'tags' in post ? post.tags : post.data?.tags ?? [];
	const postCats = 'categories' in post ? post.categories : post.data?.categories ?? [];
	for (const tag of postTags ?? []) {
		tags.set(tag, (tags.get(tag) || 0) + 1);
	}
	for (const cat of postCats ?? []) {
		categories.set(cat, (categories.get(cat) || 0) + 1);
	}
}

const allTags = [...tags.entries()].sort((a, b) => b[1] - a[1]);
const allCategories = [...categories.entries()].sort((a, b) => b[1] - a[1]);
const maxCount = allTags.length > 0 ? Math.max(...allTags.map((t) => t[1])) : 1;

function tagColor(count: number): string {
	if (count >= 3) return 'rgb(37, 99, 235)';
	if (count >= 2) return 'rgb(96, 165, 250)';
	return 'rgb(147, 197, 253)';
}
---

<section class="bg-gray-50 dark:bg-gray-900 rounded-2xl p-6">
	{allCategories.length > 0 && (
		<div class="mb-6">
			<h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3">Categories</h3>
			<div class="flex flex-wrap gap-2">
				{allCategories.map(([cat, count]) => (
					<a
						href={`/blog?category=${encodeURIComponent(cat)}`}
						class="inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-sm font-medium bg-blue-100 dark:bg-blue-900/50 text-blue-700 dark:text-blue-300 no-underline hover:bg-blue-200 dark:hover:bg-blue-900 transition-colors"
					>
						{cat}
						<span class="text-xs text-blue-500 dark:text-blue-400">({count})</span>
					</a>
				))}
			</div>
		</div>
	)}
	{allTags.length > 0 && (
		<div>
			<h3 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-3">Tags</h3>
			<div class="flex flex-wrap gap-2">
				{allTags.map(([tag, count]) => (
					<a
						href={`/blog?tag=${encodeURIComponent(tag)}`}
						class="inline-flex items-center gap-1 px-3 py-1 rounded-lg text-sm no-underline transition-colors hover:text-blue-600 dark:hover:text-blue-400"
						style={{
							fontSize: `${0.75 + (count / maxCount) * 0.5}rem`,
							color: tagColor(count),
						}}
					>
						#{tag}
					</a>
				))}
			</div>
		</div>
	)}
</section>
