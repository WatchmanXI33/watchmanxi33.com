---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
import { fetchNavigation } from '../utils/sanity';

const navData = await fetchNavigation();
const navItems = navData?.mainNavigation || [];
---

<header class="sticky top-0 z-50 bg-white/80 dark:bg-gray-900/80 backdrop-blur-sm border-b border-gray-200 dark:border-gray-800">
	<nav class="max-w-6xl mx-auto flex items-center justify-between px-4 h-16">
		<a href="/" class="text-xl font-bold text-gray-900 dark:text-white no-underline hover:text-blue-600 dark:hover:text-blue-400 transition-colors">
			{SITE_TITLE}
		</a>
		<div class="flex items-center gap-1">
			{navItems.length > 0 ? (
				navItems.map((item: any) => {
					const href = item.linkType === 'page' && item.slug ? `/${item.slug}` : item.url || '#';
					return <HeaderLink href={href}>{item.label}</HeaderLink>;
				})
			) : (
				<>
					<HeaderLink href="/">Home</HeaderLink>
					<HeaderLink href="/blog">Blog</HeaderLink>
					<HeaderLink href="/about">About</HeaderLink>
				</>
			)}
			<div class="ml-2 pl-2 border-l border-gray-200 dark:border-gray-700">
				<ThemeToggle />
			</div>
		</div>
	</nav>
</header>
