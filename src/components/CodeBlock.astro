---
interface Props {
	node: { language?: string; code: string };
}

const { language, code } = Astro.props.node;
---

<pre class="not-prose overflow-x-auto rounded-xl bg-gray-900 dark:bg-gray-800 p-4 my-6 relative group">
	{language && <span class="text-xs text-gray-500 dark:text-gray-400 block mb-2">{language}</span>}
	<button class="copy-btn absolute top-2 right-2 z-10 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center w-6 h-6 rounded-md bg-gray-700 hover:bg-gray-600 text-gray-300" data-code={code}>
		<svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
			<rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
			<path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
		</svg>
	</button>
	<code class="text-sm text-gray-100">{code}</code>
</pre>
